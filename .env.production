# Baked into production builds (NEXT_PUBLIC_* is not secret).
# Vercel Project → Environment Variables overrides this if the same key exists there.
NEXT_PUBLIC_APP_URL=https://eddie-crm-khaki.vercel.app
NEXT_PUBLIC_OFFLINE_MODE=false
# Default JotForm URL for QR generator (online). Override in Vercel if you use a different form.
NEXT_PUBLIC_JOTFORM_URL=https://form.jotform.com/253266939811163
# Server-side JotForm route defaults (individual/client form).
JOTFORM_FORM_ID=253266939811163
JOTFORM_FORM_ID_CLIENT=253266939811163
