{
  "name": "eddie-crm",
  "version": "1.0.0",
  "private": true,
  "description": "EDDIE CRM — contacts, campaigns, and intake",
  "author": "Eddie CRM",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev -p 3001 --hostname 0.0.0.0",
    "build": "prisma generate && next build",
    "postbuild:standalone": "node scripts/copy-standalone-assets.js",
    "build:desktop": "npm run build && npm run postbuild:standalone && electron-builder --win --config electron-builder.config.cjs",
    "package:distribution": "powershell -ExecutionPolicy Bypass -File scripts/package-distribution-zip.ps1",
    "package:distribution:folder": "powershell -ExecutionPolicy Bypass -File scripts/package-distribution-zip.ps1 -SkipZip",
    "electron:dev": "electron electron/main.cjs",
    "postinstall": "prisma generate",
    "start": "next start -p 3001 --hostname 0.0.0.0",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "create-admin": "tsx scripts/create-admin.ts",
    "setup": "node scripts/setup.js",
    "clean": "powershell -ExecutionPolicy Bypass -File scripts/clean.ps1",
    "clean-build": "npm run clean && npm run build",
    "reset": "npm run clean && if exist prisma\\dev.db del prisma\\dev.db && npx prisma generate && npx prisma db push",
    "deploy:prod": "powershell -ExecutionPolicy Bypass -File scripts/deploy-production.ps1",
    "smoke": "node scripts/smoke-test.mjs",
    "test:deep-api": "node scripts/deep-api-test.mjs",
    "test:jotform": "node scripts/test-jotform-api.mjs",
    "test:jotform-inbox-sync": "tsx scripts/run-jotform-inbox-sync-once.ts",
    "jotform:clear-sync-and-resync": "tsx scripts/clear-jotform-sync-and-resync.ts",
    "jotform:configure-dental": "node --env-file=.env.local scripts/configure-jotform-dental-form.mjs",
    "vercel:fix-cron-secret": "node scripts/set-vercel-cron-secret.mjs",
    "test:e2e": "playwright test",
    "test:deep": "npm run smoke && npm run test:deep-api && npm run test:e2e"
  },
  "dependencies": {
    "@prisma/client": "^5.7.1",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-checkbox": "^1.0.7",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.5",
    "@radix-ui/react-select": "^2.0.6",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@types/papaparse": "^5.5.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "date-fns": "^3.0.6",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.303.0",
    "next": "14.0.4",
    "nodemailer": "^6.9.7",
    "papaparse": "^5.5.3",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.2",
    "recharts": "^3.4.1",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^4.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@types/pdf-parse": "^1.1.4",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.16",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.0.4",
    "postcss": "^8.4.32",
    "prisma": "^5.7.1",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.eddiecrm.desktop",
    "productName": "Eddie CRM",
    "forceCodeSigning": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "standalone/public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron/env.template",
        "to": "env.template"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "sign": null,
      "signDlls": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "allowElevation": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  }
}
