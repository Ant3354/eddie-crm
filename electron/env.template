# Eddie CRM — desktop install
# Edit this file, then restart the Eddie CRM application.
# Location (after install): %APPDATA%\eddie-crm\.env  (Windows)

# Default (bundled installer): SQLite database shipped with the app (no separate database server).
# To use PostgreSQL instead, replace with e.g. postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=file:./prisma/dev.db

# Auto-filled on first run if still a placeholder; keep secret and do not share it.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# App URL for links inside the CRM and emails (127.0.0.1 = this PC only)
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3001

# Optional: public HTTPS URL baked into "local intake" QR codes so phones on ANY network can open the form
# (ngrok, Cloudflare Tunnel, Tailscale Funnel, etc. — must forward to this app). If unset, QR uses NEXT_PUBLIC_APP_URL.
# NEXT_PUBLIC_INTAKE_QR_BASE_URL=https://your-tunnel.example.com

# Local / LAN-only: prefer mailto, SMS links, copy, print; hide server email/SMS sends in the UI
NEXT_PUBLIC_OFFLINE_MODE=true

# Optional: campaign cron
CRON_SECRET=
