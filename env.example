# Application (use your PC's LAN IP for phone QR scans, e.g. http://192.168.1.10:3001)
NEXT_PUBLIC_APP_URL=http://localhost:3001
# Online by default. Set NEXT_PUBLIC_OFFLINE_MODE=true only for LAN-only / mailto-first workflows.
# NEXT_PUBLIC_OFFLINE_MODE=false
# Default JotForm URL shown on QR Codes page (online referrals).
# NEXT_PUBLIC_JOTFORM_URL=https://form.jotform.com/YOUR_FORM_ID
# Optional override for QR "local intake" links only
# PUBLIC_INTAKE_BASE_URL=http://192.168.1.10:3001

# Database
# For local SQLite, Prisma uses file:./dev.db automatically
# For production, use a managed Postgres (e.g., Neon/Supabase)
# DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Authentication (legacy name; prefer EDDIE_SESSION_SECRET for cookie JWT)
JWT_SECRET=your-secret-key-change-in-production-32-chars-minimum
# Sign-in cookie for /login (HS256). Strong unique value in production (16+ chars).
EDDIE_SESSION_SECRET=
# When true, middleware requires a valid session for app routes (see /login).
# EDDIE_REQUIRE_LOGIN=false

# Generic intake webhook: POST /api/webhooks/generic-intake with Authorization: Bearer <secret>
# WEBHOOK_INBOX_SECRET=

# Optional error tracking (install @sentry/nextjs and configure per Sentry docs)
# SENTRY_DSN=

# Email (optional in test mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# SMS (optional in test mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Support / Links (optional)
SUPPORT_PHONE=
SUPPORT_EMAIL=
SUPPORT_CHAT_URL=

# Cron secret for campaign processing, JotForm inbox sync, and task due reminders (Bearer CRON_SECRET)
CRON_SECRET=
# Optional: random secret for Integrations → “Sync inbox now” only (Bearer must match). Safer than reusing CRON_SECRET in the browser.
# EDDIE_UI_SYNC_SECRET=

# JotForm API (server-only — never NEXT_PUBLIC_*). Used by Integrations → “Test JotForm API”.
# Create a key: https://www.jotform.com/myaccount/api
JOTFORM_API_KEY=
# Per-form automation (tags + campaigns by form ID). Campaign names must exist in DB (see prisma/seed).
# List your account’s form IDs: npm run jotform:list-forms   (needs JOTFORM_API_KEY in .env; Node 20+)
# JOTFORM_FORM_ID_DENTAL=
# JOTFORM_FORM_ID_CLINIC=
# JOTFORM_FORM_ID_CLIENT=
# Optional: default / individual client form (also JOTFORM_FORM_ID_CONSUMER)
# Optional: default form for submission preview (e.g. dental intake form id)
JOTFORM_FORM_ID=
# Internal email for new-intake alerts when JotForm routing runs (else first ADMIN/MANAGER user)
# INTERNAL_NOTIFY_EMAIL=
# Optional: comma-separated extra form IDs to poll (in addition to JOTFORM_FORM_ID)
# JOTFORM_SYNC_FORM_IDS=253266939811163,OTHER_FORM_ID
# Set to false to poll only JOTFORM_FORM_ID + JOTFORM_SYNC_FORM_IDS (default: discover all account forms, capped)
# JOTFORM_SYNC_DISCOVER_FORMS=false
# Optional: EU accounts use https://eu-api.jotform.com
# JOTFORM_API_BASE=https://api.jotform.com

